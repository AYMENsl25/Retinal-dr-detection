# App
APP_ENV=development
APP_NAME=RetinaScope-AI
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000

# Model runtime
MODEL_DEVICE=auto
CHECKPOINT_DIR=backend/checkpoints
VESSEL_CHECKPOINT=vessel_unet.pth
LESION_CHECKPOINT=lesion_unet.pth
GRADER_CHECKPOINT=grader_cnn.pth
PREPROCESS_CONFIG=preprocess.json

# LLM mode:
# auto = call providers only when valid keys are present, otherwise use mock reports
# mock = never call providers
# provider = require provider keys
LLM_MODE=auto
CLINICAL_LLM_PROVIDER=groq
CLINICAL_LLM_MODEL=llama-3.3-70b-versatile
VISION_LLM_PROVIDER=gemini
VISION_LLM_MODEL=gemini-3.1-flash-lite
CHAT_LLM_PROVIDER=gemini
CHAT_LLM_MODEL=gemini-3.1-flash-lite
FALLBACK_LLM_PROVIDER=openrouter
FALLBACK_LLM_MODEL=openrouter/free

# Replace these placeholders with your keys.
GROQ_API_KEY=replace-with-your-groq-api-key
GEMINI_API_KEY=replace-with-your-gemini-api-key
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key

# Persistence, used in later phases
DATABASE_URL=postgresql+psycopg://retina:retina@localhost:5432/retinascope
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=retinascope-cases
